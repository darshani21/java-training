import java.io.*;
import java.util.*; 
import java.util.Scanner;

public class Solution {

    public static void main(String[] args) {
        int n;
        Scanner sc=new Scanner(System.in);
        n=sc.nextInt();
        int reverse=0;
        while(n>0)
        {
            int digit=n%10;
            reverse=reverse*10+digit;
            n=n/10;
        }
            System.out.println(reverse);
        
    }
}
